# Copy to .env and fill in. .env is gitignored -- never commit the private key.

# From your ProtonVPN WireGuard config file (see README step 1): the line
#   PrivateKey = xxxxxxxx...
WIREGUARD_PRIVATE_KEY=

# Exit country (gluetun matches Proton's server list). "Indonesia" matches the
# geo-gated LKPP targets. Examples: Indonesia | Singapore | Netherlands
SERVER_COUNTRIES=Indonesia
